{
  "name": "@schorts/redis-cache",
  "version": "1.0.0-beta.0",
  "description": "A Redis-backed cache implementation for Node.js that conforms to the Cache<T> interface from @schorts/shared-kernel. It provides TTL support, tag-based invalidation, and simple JSON serialization.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build": "npm run build:cjs && npm run build:esm",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "author": "Jorge Castillo (https://github.com/schorts99)",
  "license": "LGPL-3.0-or-later",
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "@schorts/shared-kernel": "^9.4.1",
    "@types/jest": "^30.0.0",
    "expect-type": "^1.2.2",
    "jest": "^30.1.3",
    "jest-html-reporter": "^4.3.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schorts99/redis-cache.git"
  },
  "keywords": [
    "cache",
    "redis",
    "node"
  ],
  "bugs": {
    "url": "https://github.com/schorts99/redis-cache/issues"
  },
  "homepage": "https://github.com/schorts99/redis-cache#readme",
  "peerDependencies": {
    "@schorts/shared-kernel": "^9.4.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
